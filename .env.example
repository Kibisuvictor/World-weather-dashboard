# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kaggle API credentials ────────────────────────────────────────────────────
# Get from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── shinyapps.io credentials ──────────────────────────────────────────────────
# Get from: https://www.shinyapps.io → Account → Tokens → Add Token
SHINYAPPS_ACCOUNT=your_shinyapps_account_name
SHINYAPPS_TOKEN=your_shinyapps_token
SHINYAPPS_SECRET=your_shinyapps_secret
